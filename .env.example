APP_NAME=AI Tutor MVP Backend
APP_VERSION=1.1.0
APP_ENV=production
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=https://your-netlify-site.netlify.app
DATABASE_URL=sqlite:///app_data/ai_tutor_mvp.db

# Provider switch
LLM_PROVIDER=mock
ASR_PROVIDER=mock
TTS_PROVIDER=mock
SPEECH_SCORE_PROVIDER=mock
USE_MOCK_FALLBACK=true

# Alibaba Bailian / Qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen3.6-flash

# Zhipu GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash

# Tencent Cloud ASR
TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_REGION=ap-beijing
TENCENT_ASR_ENDPOINT=asr.tencentcloudapi.com
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_en
TENCENT_ASR_POLL_INTERVAL_MS=600
TENCENT_ASR_TIMEOUT_SECONDS=45

# Tencent Cloud SOE speech scoring
TENCENT_SOE_REGION=
TENCENT_SOE_ENDPOINT=soe.cloud.tencent.com
TENCENT_SOE_APP_ID=
TENCENT_SOE_SCORE_COEFF=1.0

# Volcengine TTS
VOLC_TTS_APP_ID=
VOLC_TTS_API_KEY=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_VOICE_TYPE=BV001_streaming
VOLC_TTS_CLUSTER=volcano_tts
VOLC_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v1/tts
VOLC_TTS_ENCODING=mp3
VOLC_TTS_SPEED_RATIO=0.92
VOLC_TTS_VOLUME_RATIO=1.0
VOLC_TTS_PITCH_RATIO=1.0

# Frontend
VITE_API_BASE_URL=https://your-backend-domain/api/v1
